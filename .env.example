# ==============================================================================
# MessageMate AI — environment configuration
# Copy this file to .env and fill in the values for your setup.
# ==============================================================================

# --- Which AI provider to use --------------------------------------------
# One of: openai | groq | openrouter | together | ollama
AI_PROVIDER=openai

# --- OpenAI ------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini

# --- Groq (only needed if AI_PROVIDER=groq) -----------------------------
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL_NAME=llama-3.3-70b-versatile

# --- OpenRouter (only needed if AI_PROVIDER=openrouter) -----------------
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_NAME=openai/gpt-4o-mini

# --- Together AI (only needed if AI_PROVIDER=together) ------------------
TOGETHER_API_KEY=
TOGETHER_BASE_URL=https://api.together.xyz/v1
TOGETHER_MODEL_NAME=meta-llama/Llama-3.3-70B-Instruct-Turbo

# --- Local Ollama (only needed if AI_PROVIDER=ollama) --------------------
# No API key required — Ollama runs on your machine.
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL_NAME=llama3.1

# --- App behaviour -------------------------------------------------------
# Comma-separated list of origins allowed to call the API.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
RATE_LIMIT_PER_MINUTE=20
REQUEST_TIMEOUT_SECONDS=30
MAX_INPUT_CHARACTERS=4000
ENVIRONMENT=development

# --- Frontend --------------------------------------------------------------
# Leave empty to use Vite's dev proxy (see frontend/vite.config.ts) or same-
# origin requests behind nginx (see frontend/nginx.conf). Set this only if
# your backend is deployed at a different origin than your frontend.
VITE_API_BASE_URL=
