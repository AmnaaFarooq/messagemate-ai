# Leave empty for local dev — Vite's dev server proxies /api to
# http://localhost:8000 automatically (see vite.config.ts).
# Set this if your backend is deployed at a different origin, e.g.
# VITE_API_BASE_URL=https://messagemate-api.onrender.com
VITE_API_BASE_URL=

# Optional — Google Analytics 4 Measurement ID (looks like G-XXXXXXXXXX).
# Get one free at https://analytics.google.com. Leave empty to disable
# analytics entirely (nothing is loaded or sent when unset).
VITE_GA_MEASUREMENT_ID=
