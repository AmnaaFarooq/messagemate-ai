# Used when running the backend directly (uvicorn app.main:app) from inside
# the backend/ folder. If you're using docker-compose, edit the .env file at
# the project root instead — it's the same set of variables.

AI_PROVIDER=openai

OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini

GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL_NAME=llama-3.3-70b-versatile

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_NAME=openai/gpt-4o-mini

TOGETHER_API_KEY=
TOGETHER_BASE_URL=https://api.together.xyz/v1
TOGETHER_MODEL_NAME=meta-llama/Llama-3.3-70B-Instruct-Turbo

OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL_NAME=llama3.1

CORS_ORIGINS=http://localhost:5173,http://localhost:3000
RATE_LIMIT_PER_MINUTE=20
REQUEST_TIMEOUT_SECONDS=30
MAX_INPUT_CHARACTERS=4000
ENVIRONMENT=development
